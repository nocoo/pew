# Auth.js
AUTH_SECRET=          # openssl rand -base64 32
AUTH_GOOGLE_ID=       # Google OAuth client ID
AUTH_GOOGLE_SECRET=   # Google OAuth client secret

# Cloudflare D1 (writes still use REST API; reads use Worker when WORKER_READ_URL is set)
CF_ACCOUNT_ID=        # Cloudflare account ID
CF_D1_DATABASE_ID=    # D1 database UUID (wrangler d1 list)
CF_D1_API_TOKEN=      # Cloudflare API token with D1 read/write

# Admin
ADMIN_EMAILS=         # comma-separated admin emails (e.g. alice@example.com,bob@example.com)

# Worker ingest (writes go through Cloudflare Worker)
WORKER_INGEST_URL=    # e.g. https://pew-ingest.worker.hexly.ai/ingest
WORKER_SECRET=        # shared secret (wrangler secret put WORKER_SECRET)

# Worker read (reads go through Cloudflare Worker with native D1 binding)
# When set, getDbRead() uses the Worker adapter instead of D1 REST API.
# Remove to fall back to REST API.
WORKER_READ_URL=      # e.g. https://pew.worker.hexly.ai
WORKER_READ_SECRET=   # shared secret (wrangler secret put WORKER_READ_SECRET)
