# D1 Test Isolation — env vars for E2E tests
# Copy to packages/web/.env.test and fill in real values.
# See docs/31-d1-test-isolation.md for setup instructions.
#
# NEVER point these at production resources!

# Test D1 database (pew-db-test)
CF_D1_DATABASE_ID_TEST=<your-test-d1-database-id>

# Test Workers
WORKER_INGEST_URL_TEST=https://pew-ingest-test.worker.hexly.ai/ingest
WORKER_READ_URL_TEST=https://pew-test.worker.hexly.ai
