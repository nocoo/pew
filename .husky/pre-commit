#!/usr/bin/env sh

# pre-commit: Unit Tests + Coverage (90% threshold enforced by vitest.config.ts)
bun run test:coverage 2>&1
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo "❌ pre-commit FAILED: Unit tests or coverage threshold (90%) not met."
  exit 1
fi

echo "✅ pre-commit passed: UT + Coverage ≥90%"
